{
  "name": "reachlab",
  "private": true,
  "scripts": {
    "start": "pnpm --filter linkedin-analytics-server start",
    "dev": "NODE_ENV=development run-p dev:server dev:dashboard",
    "dev:server": "NODE_ENV=development pnpm --filter linkedin-analytics-server dev",
    "dev:dashboard": "pnpm --filter linkedin-analytics-dashboard dev",
    "test": "pnpm --filter linkedin-analytics-server test",
    "build:dashboard": "pnpm --filter linkedin-analytics-dashboard build",
    "build:extension": "pnpm --filter extension build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "npm-run-all2": "^8.0.4"
  }
}
